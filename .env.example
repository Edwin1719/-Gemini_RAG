# =============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO
# =============================================================================
# Copia este archivo a .env y completa con tus credenciales reales
# ¡NUNCA compartas tu archivo .env real ni lo subas a GitHub!
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini API Key
# -----------------------------------------------------------------------------
# Obtén tu API Key en: https://makersuite.google.com/app/apikey
# o en: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=tu_api_key_aqui

# -----------------------------------------------------------------------------
# Configuración Opcional de la Aplicación
# -----------------------------------------------------------------------------
# Estas variables son opcionales y se pueden configurar desde la interfaz

# Modelo de Embedding (por defecto: gemini-embedding-2-preview)
# EMBEDDING_MODEL=gemini-embedding-2-preview

# Modelo LLM (por defecto: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash

# Ruta de la base de datos ChromaDB (por defecto: ./chroma_db)
# CHROMA_DB_PATH=./chroma_db

# Puerto de Streamlit (por defecto: 8501)
# STREAMLT_PORT=8501

# -----------------------------------------------------------------------------
# Notas Importantes
# -----------------------------------------------------------------------------
# 1. El archivo .env NO debe subirse a GitHub
# 2. Cada desarrollador debe crear su propio .env local
# 3. Usa este archivo .env.example como plantilla
# 4. Para más información, consulta el README.md
# =============================================================================
